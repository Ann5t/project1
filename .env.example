# ============================================================================
# AI Agent 环境变量配置
# 复制此文件为 .env 并修改
#
# 所有变量均有合理默认值，确保 .env 不存在时服务也能正常启动。
# ============================================================================

# ── 服务器配置 ───────────────────────────────────
BIND_ADDRESS=0.0.0.0:3000
BIND_PORT=3000
RUST_LOG=info

# ── 数据库路径 ───────────────────────────────────
# Docker 内使用 /app/data/agent.db
DATABASE_PATH=data/agent.db

# ── 前端静态文件路径 ─────────────────────────────
# Docker 内使用 /app/frontend
FRONTEND_DIR=crates/agent-frontend

# ── CORS 跨域来源 ────────────────────────────────
# 允许的来源，逗号分隔。留空表示允许所有来源（仅开发环境推荐）。
# CORS_ORIGIN=https://ai.example.com

# ── 请求超时 (秒) ────────────────────────────────
REQUEST_TIMEOUT_SECS=60

# ── 工具安全配置 ─────────────────────────────────
# 启用 Shell 执行工具（有安全风险，生产环境慎用）
SHELL_TOOL_ENABLED=false

# ReadFileTool 允许访问的文件目录
ALLOWED_DATA_DIR=data

# ExecuteShellTool 允许的命令白名单，逗号分隔。留空允许所有命令。
# ALLOWED_COMMANDS=echo,cat,ls,pwd,date

# ExecuteShellTool 单命令超时秒数
SHELL_TIMEOUT_SECS=30
